              "RenderingSkip": 0,
              "MinimumRefreshIntervalMS": 0.0,
              "Bindings": {
                "Text": {
                  "Formula": {
                    "JSExt": 0,
                    "Interpreter": 1,
                    "Expression": "var name = $prop('variable.cornerName') || '';\nvar dir = $prop('variable.cornerDirection') || '';\nif (!name && !dir) {\n  var next = $prop('variable.nextCornerName') || '';\n  return next ? '> ' + next : '';\n}\nvar display = name;\nif (dir) display = dir + ' - ' + name;\nreturn display;"
                  },
                  "Mode": 2
                },
                "TextColor": {
                  "Formula": {
                    "JSExt": 0,
                    "Interpreter": 1,
                    "Expression": "var name = $prop('variable.cornerName') || '';\nreturn name ? '#FFFFFFFF' : '#99AAAAAA';"
